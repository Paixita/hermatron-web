# Clave de API de Groq (obténla en https://console.groq.com)
GROQ_API_KEY=tu_api_key_aqui

# Clave de API de Serper para búsquedas web (opcional, https://serper.dev)
SERPER_API_KEY=tu_api_key_aqui

# Puerto del servidor
PORT=5000

# Host del servidor
HOST=0.0.0.0

# Modo debug (True para desarrollo, False para producción)
DEBUG=True

# Modelo de Groq a usar
GROQ_MODEL=llama-3.3-70b-versatile

# Voz para Edge-TTS (ej: es-MX-JorgeNeural, es-CO-GonzaloNeural, etc.)
TTS_VOICE=es-MX-JorgeNeural
